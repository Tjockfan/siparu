# Dependencies and build output
node_modules/
dist/
*.log
.env
.env.*
.DS_Store

# Webapp build output - shipped via package.json "files", not committed.
# Anchored: a bare "public/" matches at any depth, which also swallowed the
# webapp/public source tree, so a fresh clone built a PWA with no favicon and no
# manifest. Only the generated top-level directory belongs here.
/public/

# Local test sandbox
.sandbox/

# Local dev tooling (synthetic data feeder, not shipped)
dev/

# npm pack output
*.tgz
